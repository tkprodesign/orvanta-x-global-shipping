modules = ["php-8.2", "web", "nodejs-20"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash /home/runner/workspace/start-mysql.sh"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
DB_HOST = "127.0.0.1"
DB_USER = "shipping_user"
DB_PASS = "shipping_pass"
DB_NAME = "shipping_db"
DB_SOCKET = "/home/runner/mysql-run/mysql.sock"

[deployment]
deploymentTarget = "vm"
run = ["bash", "/home/runner/workspace/start-mysql.sh"]
